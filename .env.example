# Firebase web config (public values, safe to commit per-environment). Copy to
# .env.local and fill from the Firebase console (Project settings → Your apps).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=ownit-afc0f.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ownit-afc0f
VITE_FIREBASE_STORAGE_BUCKET=ownit-afc0f.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to point the local dev app at the Firebase emulator suite.
VITE_USE_EMULATORS=false
